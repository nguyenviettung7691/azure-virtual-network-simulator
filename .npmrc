# Increase Node.js heap for all npm scripts (dev server, build, generate).
# Nuxt 3 dev mode accumulates memory over long sessions; the default 4 GB
# V8 heap limit causes OOM when a forced in-process rebuild is triggered
# (e.g. .nuxt/dist removed externally). 8 GB gives sufficient headroom.
node-options=--max-old-space-size=8192
